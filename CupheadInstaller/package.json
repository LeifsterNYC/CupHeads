{
  "name": "cupheads-installer",
  "version": "1.2.0",
  "description": "Installer for the Cupheads multiplayer mod",
  "author": "Germanized / Sh0kr",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predist": "node scripts/copy-dll.js",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.cupheads.installer",
    "productName": "Cupheads",
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "assets/cupheads.ico"
    },
    "extraResources": [
      { "from": "assets", "to": "assets", "filter": ["**/*"] }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "node_modules/**"
    ],
    "portable": {
      "artifactName": "Cupheads.exe"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.10"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
